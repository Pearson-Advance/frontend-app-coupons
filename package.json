{
  "name": "frontend-app-coupons",
  "version": "0.1.0",
  "description": "Frontend app coupons.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pearson-Advance/frontend-app-coupons"
  },
  "browserslist": [
    "extends @edx/browserslist-config"
  ],
  "scripts": {
    "build": "fedx-scripts webpack",
    "i18n_extract": "BABEL_ENV=i18n fedx-scripts babel src --quiet > /dev/null",
    "stylelint": "stylelint \"src/**/*.scss\" --config .stylelintrc.json",
    "lint": "npm run stylelint && fedx-scripts eslint --ext .js --ext .jsx --ext .ts --ext .tsx . && npm run types",
    "lint:fix": "npm run stylelint && fedx-scripts eslint --ext .js --ext .jsx --ext .ts --ext .tsx . --fix",
    "snapshot": "fedx-scripts jest --updateSnapshot",
    "start": "fedx-scripts webpack-dev-server --progress",
    "test": "fedx-scripts jest --coverage --passWithNoTests",
    "types": "tsc --noEmit"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run lint"
    }
  },
  "author": "edunext contact@edunext.co",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Pearson-Advance/frontend-app-coupons#readme",
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/Pearson-Advance/frontend-app-coupons/issues"
  },
  "dependencies": {
    "@edx/brand": "npm:@edx/brand-openedx@1.2.0",
    "@edx/frontend-component-footer": "^14.6.0",
    "@edx/frontend-platform": "^8.4.0",
    "@openedx/paragon": "^23.4.5",
    "@tanstack/react-query": "^5.95.2",
    "dompurify": "^3.3.1",
    "html-react-parser": "^5.2.17",
    "prop-types": "15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-intl": "^5.25.1",
    "react-paragon-topaz": "^2.3.1",
    "react-router": "^6.15.0",
    "react-router-dom": "^6.15.0",
    "react-select": "5.10.2"
  },
  "devDependencies": {
    "@edx/browserslist-config": "^1.1.1",
    "@edx/reactifex": "^2.2.0",
    "@edx/stylelint-config-edx": "^2.3.3",
    "@edx/typescript-config": "^1.1.0",
    "@openedx/frontend-build": "14.6.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "glob": "11.1.0"
  }
}
